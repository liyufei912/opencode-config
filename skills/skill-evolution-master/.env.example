# Skill Evolution — Configuration Template
# ==========================================
# SECURITY WARNING:
# - Never commit this file or .env to version control
# - This file contains PLACEHOLDERS only, replace with real credentials
# - Add both .env and .env.local to your .gitignore
# - Never share your actual credentials

# --- Private registry (advanced) ---
# Override to use your own Supabase instance instead of the public registry.
#
# Required for all operations (replace with your values):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Required for admin operations (audit, reset publisher keys):
# SUPABASE_SERVICE_KEY=your-service-role-key-here
