# Skill Evolution — Configuration
#
# SECURITY: Never commit this file to version control
# Add .env to your .gitignore if not already present

# --- Private registry (advanced) ---
# Override to use your own Supabase instance instead of the public registry.
#
# Required for all operations:
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Required for admin operations (audit, reset publisher keys):
# SUPABASE_SERVICE_KEY=your-service-role-key-here
